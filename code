index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
| eval all_urls=split('filter.modules.urldefense.url'," ")
| mvexpand all_urls
| where len(all_urls) > 0
| where match(all_urls,"(?i)^http")
| where NOT match(lower(all_urls),
        "(?i)teams\.microsoft\.com|zoom\.us|webex\.com|meet\.google\.com|gotomeeting\.com|skype\.com|bluejeans\.com|chime\.aws|whereby\.com|ringcentral\.com")
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        all_urls,
        'connection.ip',
        'connection.country',
        'filter.modules.dmarc.filterdResult',
        'filter.modules.spf.result'
| sort -_time
