index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
| spath output=urls path=msgParts{}.urls{}.url
| where mvcount(urls) > 0
| eval recipient=mvindex('envelope.rcpts{}',0)
| eval subject=mvindex('msg.normalizedHeader.subject{}',0)
| mvexpand urls
| where NOT match(lower(urls),
        "(?i)^mailto:|teams\.microsoft\.com|zoom\.us|webex\.com|meet\.google\.com|gotomeeting\.com|skype\.com|bluejeans\.com|chime\.aws|whereby\.com|ringcentral\.com")
| where match(lower(urls),"(?i)^http|^ftp")
| table _time, action,
        'envelope.from',
        recipient,
        subject,
        urls,
        'connection.ip',
        'connection.country',
        'filter.modules.dmarc.filterdResult',
        'filter.modules.spf.result'
| sort _time, urls
