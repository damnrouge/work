HUNT-13 — Full Attack Lifecycle Create → Update → Delete on Same Meeting
-------------------------------------------------------------------------
index=o365 sourcetype="o365:management:activity"
Workload=Exchange
command IN ("Create","Update","SoftDelete","HardDelete","MoveToDeletedItems")
object_category=meeting
| stats values(command) as commands,
        min(_time) as first_seen,
        max(_time) as last_seen,
        values(UserId) as users,
        values(src_ip) as src_ips,
        values(ClientInfoString) as clients
        by object
| where mvcount(commands) >= 3
| eval lifecycle_mins=round((last_seen-first_seen)/60,1)
| eval attack_chain=mvjoin(commands," → ")
| table object, attack_chain, users,
        src_ips, clients,
        first_seen, last_seen, lifecycle_mins
| sort lifecycle_mins


