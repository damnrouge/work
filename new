Workload=Exchange command=Update
object_category=meeting
| where ExternalAccess="true"
      OR match(ClientInfoString,"(?i)REST|Graph")
| table _time, UserId, command,
        object, object_category,
        'Item.Subject',
        'Item.ParentFolder.Path',
        ClientInfoString,
        ExternalAccess,
        src_ip, ResultStatus,
        MailboxOwnerUPN
