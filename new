HUNT-11 — Calendar Event Created With ICS Attachment
-----------------------------------------------------
index=o365 sourcetype="o365:management:activity"
Workload=Exchange command=Create
object_category=meeting
| where match('Item.Attachments',"(?i)\.ics")
| table _time, UserId, command,
        object, object_category,
        'Item.Attachments',
        'Item.Subject',
        'Item.ParentFolder.Path',
        ClientInfoString,
        ExternalAccess,
        src_ip, ResultStatus
| sort -_time


HUNT-12 — Calendar Event Updated From External Source (UID Hijack)
------------------------------------------------------------------
