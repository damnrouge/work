INDEX    : proofpoint
SOURCETYPE: pps_messagelog
DESCRIPTION: Proofpoint Protection Server (PPS) raw mail processing logs —
             full MIME inspection, per-part attachment metadata, SPF/DKIM/DMARC
             results, spam scores per classifier, URL defense rewrite counts,
             sandbox verdicts per part, connection metadata. Most granular email
             log available. Captures ICS files even when no TAP verdict is fired.
================================================================================

HUNT-05 — ICS File Detected in Any Delivered Email
---------------------------------------------------
index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
      OR mvfind('msgParts{}.labeledExt',"(?i)^ics$") >= 0
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        'msgParts{}.detectedExt',
        'msgParts{}.sandboxStatus',
        'filter.modules.spam.scores.overall',
        'connection.ip',
        'connection.country',
        'filter.modules.urldefense.counts.rewritten'
| sort -_time


HUNT-06 — ICS File Delivered With URL Rewritten (Proofpoint Saw the URL)
-------------------------------------------------------------------------
index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
| where 'filter.modules.urldefense.counts.rewritten' > 0
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        'filter.modules.urldefense.counts.rewritten',
        'filter.modules.urldefense.counts.total',
        'filter.modules.urldefense.counts.unrewritten',
        'connection.ip', 'connection.country'
| sort -_time


HUNT-07 — ICS File Delivered With URL NOT Rewritten (DETECTION GAP)
--------------------------------------------------------------------
index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
| where 'filter.modules.urldefense.counts.rewritten' = 0
      AND 'filter.modules.urldefense.counts.total' > 0
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        'filter.modules.urldefense.counts.rewritten',
        'filter.modules.urldefense.counts.total',
        'filter.modules.urldefense.counts.unrewritten',
        'connection.ip', 'connection.country'
| sort -_time


HUNT-08 — ICS File From External Country With Sandbox NOT SUPPORTED
--------------------------------------------------------------------
index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
| where mvfind('msgParts{}.sandboxStatus',"NOT_SUPPORTED") >= 0
| where NOT match('connection.country',"(?i)^us$")
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        'msgParts{}.sandboxStatus',
        'connection.ip',
        'connection.country',
        'filter.modules.dmarc.filterdResult',
        'filter.modules.spf.result'
| sort -_time


HUNT-09 — ICS File With DMARC or SPF Failure
---------------------------------------------
index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
      OR mvfind('msgParts{}.detectedMime',"(?i)text/calendar") >= 0
| where 'filter.modules.dmarc.filterdResult' != "pass"
      OR 'filter.modules.spf.result' != "pass"
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        'filter.modules.dmarc.filterdResult',
        'filter.modules.spf.result',
        'filter.modules.dkimv{}.result',
        'connection.ip', 'connection.country'
| sort -_time


HUNT-10 — Multiple ICS Files in Same Email
------------------------------------------
index=proofpoint sourcetype=pps_messagelog
| where mvfind('msgParts{}.detectedExt',"(?i)^ICS$") >= 0
| eval ics_count=mvcount(mvfilter(match('msgParts{}.detectedExt',"(?i)^ICS$")))
| where ics_count > 1
| eval recipient=mvindex('envelope.rcpts{}',0)
| table _time, action,
        'envelope.from',
        recipient,
        'msg.normalizedHeader.subject{}',
        'msgParts{}.detectedName',
        ics_count,
        'connection.ip',
        'connection.country'
| sort -ics_count


