HUNT-15 — Same Meeting Updated by Different User (Lateral Spread)
-----------------------------------------------------------------
index=o365 sourcetype="o365:management:activity"
Workload=Exchange
command IN ("Create","Update")
object_category=meeting
| stats values(command) as commands,
        values(UserId) as users,
        dc(UserId) as distinct_users,
        dc(MailboxOwnerUPN) as affected_mailboxes,
        min(_time) as first_seen,
        max(_time) as last_seen,
        values(src_ip) as src_ips
        by object
| where distinct_users > 1
      OR affected_mailboxes > 3
| eval time_gap_mins=round((last_seen-first_seen)/60,1)
| table object, commands, users, distinct_users,
        affected_mailboxes, src_ips,
        first_seen, last_seen, time_gap_mins
| sort -affected_mailboxes


HUNT-16 — Calendar Event Created Then Cancelled Within 24 Hours (Cleanup)
--------------------------------------------------------------------------
index=o365 sourcetype="o365:management:activity"
Workload=Exchange
command IN ("Create","SoftDelete","HardDelete","MoveToDeletedItems")
object_category=meeting
| stats values(command) as commands,
        min(_time) as first_seen,
        max(_time) as last_seen,
        values(UserId) as users,
        values(MailboxOwnerUPN) as mailboxes
        by object
| where mvfind(commands,"Create") >= 0
      AND (mvfind(commands,"SoftDelete") >= 0
           OR mvfind(commands,"HardDelete") >= 0
           OR mvfind(commands,"MoveToDeletedItems") >= 0)
| eval lifecycle_mins=round((last_seen-first_seen)/60,1)
| where lifecycle_mins < 1440
| table object, commands, users, mailboxes,
        first_seen, last_seen, lifecycle_mins
| sort lifecycle_mins


